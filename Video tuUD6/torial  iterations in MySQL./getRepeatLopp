CREATE DEFINER=`root`@`localhost` PROCEDURE `getRepeatLopp`()

BEGIN

-- I do the declares, important doing them before of all

DECLARE x INT ; -- 

DECLARE string_value varchar(50);

-- I give initial values to them 

SET x=1;

SET string_value =""; 




REPEAT 

 SET string_value = CONCAT(string_value,x," , ");

    SET x=x+1;

 UNTIL x > 10

END REPEAT;

SELECT string_value;


END


