db.runCommand({

  collMod: "client",

  validator: {

    $jsonSchema: {

      bsonType: "object",

      required: [

        "clientName",

        "telephone",

        "city",

        "street",

        "number",

        "state",

        "birthdate"

      ],

      properties: {

        _id: {

          bsonType: "objectId"

        },

        clientName: {

          bsonType: "string"

        },

        telephone: {

          bsonType: "string",

          pattern: "^[0-9+()\\-\\s]{7,20}$"

        },

        city: {

          bsonType: "string"

        },

        street: {

          bsonType: "string"

        },

        number: {

          bsonType: "int",

          minimum: 1

        },

        state: {

          bsonType: "string",

          minLength: 2,

          maxLength: 2

        },

        birthdate: {

          bsonType: "string",

          pattern: "^\\d{4}-\\d{2}-\\d{2}$"

        }

      }

    }

  },

  validationLevel: "strict",

  validationAction: "error"

})

